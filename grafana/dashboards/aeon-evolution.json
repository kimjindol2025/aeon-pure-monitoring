{
  "dashboard": {
    "title": "AEON Evolution Monitor",
    "tags": ["aeon", "evolution", "sovereignty"],
    "timezone": "browser",
    "schemaVersion": 16,
    "version": 1,
    "refresh": "5s",
    "panels": [
      {
        "id": 1,
        "title": "Fitness Evolution (적합도 진화)",
        "type": "graph",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
        "targets": [
          {
            "rawSql": "SELECT timestamp as time, fitness FROM evolution_stats ORDER BY timestamp ASC",
            "format": "time_series"
          }
        ],
        "yaxes": [
          {"label": "Fitness", "format": "short"},
          {"show": false}
        ]
      },
      {
        "id": 2,
        "title": "Generation Progress (세대 진행)",
        "type": "graph",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
        "targets": [
          {
            "rawSql": "SELECT timestamp as time, generation FROM evolution_stats ORDER BY timestamp ASC",
            "format": "time_series"
          }
        ],
        "yaxes": [
          {"label": "Generation", "format": "short"},
          {"show": false}
        ]
      },
      {
        "id": 3,
        "title": "Current Status (현재 상태)",
        "type": "stat",
        "gridPos": {"h": 4, "w": 6, "x": 0, "y": 8},
        "targets": [
          {
            "rawSql": "SELECT status FROM evolution_stats ORDER BY timestamp DESC LIMIT 1",
            "format": "table"
          }
        ]
      },
      {
        "id": 4,
        "title": "Active Workers (활성 작업자)",
        "type": "gauge",
        "gridPos": {"h": 4, "w": 6, "x": 6, "y": 8},
        "targets": [
          {
            "rawSql": "SELECT workers FROM evolution_stats ORDER BY timestamp DESC LIMIT 1",
            "format": "table"
          }
        ],
        "options": {
          "minValue": 0,
          "maxValue": 10
        }
      },
      {
        "id": 5,
        "title": "Error Count (에러 카운트)",
        "type": "stat",
        "gridPos": {"h": 4, "w": 6, "x": 12, "y": 8},
        "targets": [
          {
            "rawSql": "SELECT SUM(errors) as total_errors FROM evolution_stats",
            "format": "table"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"value": 0, "color": "green"},
                {"value": 1, "color": "yellow"},
                {"value": 10, "color": "red"}
              ]
            }
          }
        }
      },
      {
        "id": 6,
        "title": "Recent Errors (최근 에러)",
        "type": "table",
        "gridPos": {"h": 6, "w": 24, "x": 0, "y": 12},
        "targets": [
          {
            "rawSql": "SELECT datetime(timestamp, 'unixepoch', 'localtime') as time, error_msg FROM error_logs ORDER BY timestamp DESC LIMIT 10",
            "format": "table"
          }
        ]
      }
    ]
  }
}
